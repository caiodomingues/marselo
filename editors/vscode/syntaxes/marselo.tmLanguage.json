{
  "name": "Marselo",
  "scopeName": "source.mrs",
  "fileTypes": [
    "mrs"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#native-functions"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.double-slash.mrs",
      "match": "//.*$"
    },
    "strings": {
      "name": "string.quoted.double.mrs",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.mrs",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.mrs",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mrs",
          "match": "\\b(if|else|while|for|return|import)\\b"
        },
        {
          "name": "keyword.declaration.mrs",
          "match": "\\b(var|fn)\\b"
        }
      ]
    },
    "constants": {
      "name": "constant.language.mrs",
      "match": "\\b(true|false|null)\\b"
    },
    "functions": {
      "comment": "function call: name(",
      "name": "entity.name.function.mrs",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
    },
    "native-functions": {
      "comment": "built-in native functions",
      "name": "support.function.mrs",
      "match": "\\b(print|len|push|pop|range|map|split|join|upper|lower|trim|substring|input|num)\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.mrs",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.mrs",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.nullish.mrs",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.assignment.mrs",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.mrs",
          "match": "(\\+|-|\\*|/|%)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.mrs",
          "match": ";"
        },
        {
          "name": "punctuation.separator.mrs",
          "match": ","
        },
        {
          "name": "punctuation.definition.block.mrs",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.bracket.mrs",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.definition.paren.mrs",
          "match": "[()]"
        }
      ]
    },
    "identifiers": {
      "name": "variable.other.mrs",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}